{
  "name": "goouuu-s3-cam-rc-car",
  "private": true,
  "scripts": {
    "fw:setup": "bash scripts/fw-setup-linux.sh",
    "fw:build": "cd firmware && ../scripts/pio.sh run",
    "fw:upload": "cd firmware && ../scripts/pio.sh run -t upload",
    "fw:flash": "cd firmware && ../scripts/pio.sh run && ../scripts/pio.sh run -t upload",
    "fw:monitor": "cd firmware && ../scripts/pio.sh device monitor -b 115200 --filter direct",
    "fw:test": "cd firmware && ../scripts/pio.sh run -t upload && ../scripts/pio.sh device monitor -b 115200"
  }
}
