; Copy to platformio.local.ini (gitignored) and adjust for your network.

[env:goouuu-s3-cam]
build_flags =
    -DWIFI_SSID=\"your-network\"
    -DWIFI_PASS=\"your-password\"
    -DFOLIO_BRAIN_URL=\"http://192.168.1.100:8770\"
    -DFOLIO_DEVICE_ID=\"folio-s3-01\"
upload_port = /dev/ttyACM0
monitor_port = /dev/ttyACM0
