; Copy to platformio.local.ini (gitignored) and adjust for your LAN.
;
; ESP must reach the brain on the SAME subnet as its WiFi.
; Brain auto-sends brainUrl on /api/node/config (matched by ESP client IP).
; First contact still uses FOLIO_BRAIN_URL below — pick any reachable LAN IP.

[env:goouuu-s3-cam]
build_flags =
    -DFOLIO_BRAIN_URL=\"http://192.168.28.28:8770\"
    ; PC IP on the open WiFi subnet (example). Or set node.brainUrl in ~/.folio/config.json
