{
  "name": "goouuu-s3-cam-folio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "jpeg-js": "^0.4.4",
    "onnxruntime-node": "^1.21.0"
  },
  "scripts": {
    "fw:setup": "bash ../../../scripts/fw-setup-linux.sh",
    "fw:build": "bash ../../../scripts/pio.sh run -d firmware",
    "fw:upload": "bash ../../../scripts/pio.sh run -d firmware -t upload",
    "fw:flash": "bash ../../../scripts/pio.sh run -d firmware && bash ../../../scripts/pio.sh run -d firmware -t upload",
    "fw:monitor": "bash ../../../scripts/pio.sh device monitor -d firmware -b 115200 --filter direct",
    "brain": "node --watch scripts/folio-brain.mjs",
    "brain:prod": "node scripts/folio-brain.mjs",
    "cli": "node scripts/folio.mjs",
    "process": "node scripts/folio.mjs process",
    "insights": "node scripts/folio.mjs insights --today --force",
    "memory:reindex": "node scripts/folio.mjs memory reindex",
    "enroll": "node scripts/folio.mjs enroll"
  }
}
