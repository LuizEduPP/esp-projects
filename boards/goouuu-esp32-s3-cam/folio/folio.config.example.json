{
  "locale": "pt-BR",
  "port": 8770,
  "dataDir": null,
  "lm": {
    "url": "http://127.0.0.1:1234/v1/chat/completions",
    "model": "mistralai/ministral-3-3b"
  },
  "frames": {
    "captureIntervalMs": 60000,
    "captionIntervalMs": 60000,
    "captionMaxTokens": 220,
    "captionTemperature": 0.05,
    "pipelineBatch": 1,
    "jpegQuality": 12,
    "size": "QVGA"
  },
  "audio": {
    "chunkMs": 1000,
    "sampleRate": 16000,
    "speechEnergyThreshold": 0.008,
    "whisperBin": "whisper",
    "whisperModel": "base",
    "whisperDevice": "cuda",
    "whisperTimeoutMs": 120000,
    "whisperLanguage": null,
    "pipelineBatch": 4,
    "retentionDays": 7,
    "retentionSweepMs": 21600000
  },
  "pipeline": {
    "enabled": true,
    "intervalMs": 30000
  },
  "worker": {
    "backlogHigh": 200,
    "backlogMedium": 50,
    "batchMaxHigh": 12,
    "batchMaxMedium": 8
  },
  "digest": {
    "auto": true,
    "intervalMs": 1800000,
    "passDTemperature": 0.35
  },
  "episodes": {
    "gapMin": 12,
    "frameAlignMs": 60000,
    "graphEdge": {
      "themed": 0.8,
      "decided": 0.7,
      "open": 0.75,
      "rejected": 0.9
    }
  },
  "memory": {
    "enabled": true,
    "lookbackDays": 90,
    "retrieveLimit": 14,
    "minScore": 0.08,
    "useEmbeddings": false,
    "graphRetrieveLimit": 8,
    "graphMinScore": 0.15,
    "profileLimit": 32,
    "minFactTextLength": 5,
    "fallbackLexical": false
  },
  "node": {
    "wifiRetryMs": 5000,
    "pushBackoffMaxMs": 30000,
    "statusIntervalMs": 15000
  }
}
